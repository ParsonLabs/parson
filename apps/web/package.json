  "private": true,
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "bun --bun next dev --webpack",
    "type-check": "node -e \"require('fs').rmSync('.next/types',{recursive:true,force:true})\" && bun --bun next typegen && bun --bun tsc --pretty --noEmit",
    "build": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && bun --bun next build --webpack",
    "start": "bunx serve out"
  },
  "dependencies": {
    "@parson/music-sdk": "*",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-context-menu": "2.3.3",
