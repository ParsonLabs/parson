{
  "name": "parson-music",
  "version": "1.0.0",
  "private": true,
  "license": "GPL-3.0-only",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "start": "turbo start",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown"
  },
  "devDependencies": {
    "prettier": "3.9.5",
    "turbo": "2.10.5",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "postcss": "8.5.19",
    "sharp": "0.35.0",
    "uuid": "11.1.1"
  },
  "patchedDependencies": {
    "react-native-audio-api@0.13.2": "apps/mobile/patches/react-native-audio-api@0.13.2.patch"
  }
}
